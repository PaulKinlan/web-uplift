      "principleCheckId": "input-modality-aware",
      "guidanceId": "accessibility",
      "guidanceCategory": "accessibility",
      "severity": "high",
      "confidence": "high",
      "summary": "Focus outline removed with no :focus-visible replacement.",
      "evidence": "An evaluate probe that focuses .pf-btn and reads the computed outline returned outline-style: none; CSS inspection found .pf-btn { outline: none } and no :focus-visible rule restoring an outline. Keyboard users get no visible focus indicator.",
      "suggestedFix": "Remove the blanket outline: none and add .pf-btn:focus-visible { outline: 3px solid #1a73e8; outline-offset: 2px } so keyboard focus is clearly indicated without affecting pointer clicks.",
      "effort": "trivial",
      "scenario": "poor-focus",
      "artifacts": [
        "evidence/poor-focus.png"
      ]
    },
    {
      "id": "F-005",
      "pathId": "layout-shift",
      "url": "http://localhost:8090/#layout-shift",
      "principleId": "be-fast-and-stable",
      "principleCheckId": "visual-stability",
      "guidanceId": "css",
      "guidanceCategory": "css",
      "severity": "medium",
      "confidence": "high",
      "summary": "Cumulative layout shift from a late banner with no reserved space.",
      "evidence": "The layout primitive's layout-shift observer recorded CLS 0.0118 across 2 shifts as the banner injected at ~600ms pushed following content down; the .ls-slot reserves no height. CLS is small here because the page is tall, but the mechanism (unreserved late content) is the classic CLS anti-pattern and scales with banner size.",
      "suggestedFix": "Reserve the banner's space up front with min-height (or aspect-ratio) on .ls-slot so the late content does not shift surrounding layout.",
      "effort": "trivial",
      "scenario": "layout-shift",
      "artifacts": [
        "evidence/trace-summary.json"
      ]
    },
